/* pages/photo/photo.wxss */

.photo-page {
  min-height: 100vh;
  background: #F2F3F5;
}

/* ── 顶栏（复用 scan 同款） ── */
.brand-bar { background: #1A1A1A; flex-shrink: 0; }
.brand-bar-inner {
  height: 44px; display: flex; align-items: center; justify-content: space-between; padding: 0 20px;
}
.logo-wrap { display: flex; flex-direction: column; line-height: 1; }
.logo-le { font-size: 11px; font-weight: 700; color: #F5D547; letter-spacing: 0.5px; }
.logo-shine { font-size: 22px; font-weight: 900; color: #F5D547; letter-spacing: -0.5px; font-style: italic; }
.logo-hair { font-size: 10px; font-weight: 600; color: rgba(245,213,71,0.6); letter-spacing: 2px; margin-top: 1px; }
.brand-bar-right { color: rgba(245,213,71,0.65); font-size: 13px; font-weight: 500; }

.nav-bar {
  background: #1A1A1A;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-title { color: #F5D547; font-size: 17px; font-weight: 700; }

/* ── 页面内容 ── */
.page-content {
  padding: 20px;
}

/* ── 开发中提示条 ── */
.coming-bar {
  background: #FFFBE8;
  border: 1px solid #F5D547;
  border-radius: 12px;
  padding: 12px 16px;
  margin-bottom: 18px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.coming-icon { font-size: 18px; }
.coming-text { color: #7A6100; font-size: 14px; }

/* ── 上传区 ── */
.upload-zone {
  border: 2px dashed #F5D547;
  border-radius: 20px;
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  background: #FFFBE8;
  margin-bottom: 16px;
  position: relative;
  overflow: hidden;
}
.upload-zone-icon { font-size: 60px; }
.upload-zone-text { color: #555555; font-size: 16px; font-weight: 600; }

.upload-preview {
  width: 100%;
  height: 100%;
  border-radius: 18px;
}
.upload-clear {
  position: absolute;
  top: 12px;
  right: 12px;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(26,26,26,0.6);
  color: #FFFFFF;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ── 说明文字 ── */
.upload-hint {
  color: #999999;
  font-size: 14px;
  text-align: center;
  line-height: 1.7;
  margin-bottom: 24px;
  display: block;
}

/* ── Disabled 按钮 ── */
.btn-disabled {
  width: 100%;
  height: 54px;
  border-radius: 27px;
  background: #E5E5E5;
  color: #999999;
  font-size: 16px;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
}
