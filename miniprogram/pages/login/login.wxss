/* pages/login/login.wxss */

.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1A1A1A 0%, #2D2D2D 50%, #F2F3F5 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 180rpx;
}

/* ── Logo ── */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}
.logo-wrap {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  line-height: 1;
}
.logo-le {
  font-size: 52rpx;
  font-weight: 700;
  color: #F5D547;
  letter-spacing: 0;
  font-style: italic;
}
.logo-shine {
  font-size: 52rpx;
  font-weight: 900;
  color: #F5D547;
  letter-spacing: -1rpx;
  font-style: italic;
}
.logo-hair {
  font-size: 52rpx;
  font-weight: 900;
  color: rgba(245,213,71,0.6);
  letter-spacing: -1rpx;
  font-style: italic;
}
.logo-subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 24rpx;
  font-weight: 500;
}

/* ── 表单 ── */
.form-area {
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.12);
}
.form-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}
.form-desc {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 40rpx;
  line-height: 1.6;
}
.form-input {
  width: 100%;
  height: 88rpx;
  background: #F2F3F5;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  margin-bottom: 32rpx;
  box-sizing: border-box;
}
.input-placeholder {
  color: #C4CDD6;
}
.btn-bind {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background: #F5D547;
  color: #1A1A1A;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
.btn-bind[disabled] {
  background: #E5E5E5;
  color: #999999;
}

/* ── 自动登录 ── */
.auto-login {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}
.spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid rgba(245,213,71,0.3);
  border-top-color: #F5D547;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.auto-login-text {
  color: rgba(255,255,255,0.7);
  font-size: 28rpx;
}
