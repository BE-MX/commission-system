/* pages/history/history.wxss */

.history-page {
  min-height: 100vh;
  background: #F2F3F5;
  display: flex;
  flex-direction: column;
}

/* ── 顶部导航栏 ── */
.top-bar {
  background: #1A1A1A;
  flex-shrink: 0;
  position: sticky;
  top: 0;
  z-index: 100;
}
.nav-bar-inner {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
}
.nav-back {
  display: flex;
  align-items: center;
  gap: 4px;
}
.back-arrow {
  color: #F5D547;
  font-size: 24px;
  font-weight: 300;
  line-height: 1;
}
.back-text {
  color: #F5D547;
  font-size: 14px;
  font-weight: 500;
}
.nav-title {
  color: #F5D547;
  font-size: 17px;
  font-weight: 700;
}
.nav-right {
  display: flex;
  align-items: center;
  gap: 4px;
}
.filter-icon {
  color: rgba(245,213,71,0.7);
  font-size: 11px;
}
.filter-text {
  color: rgba(245,213,71,0.7);
  font-size: 14px;
  font-weight: 500;
}

/* ── 筛选面板 ── */
.filter-panel {
  background: #FFFFFF;
  padding: 0 16px;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease, padding 0.3s ease;
  flex-shrink: 0;
}
.filter-panel.filter-open {
  max-height: 320px;
  padding: 16px;
}
.filter-row {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}
.filter-label {
  font-size: 14px;
  color: #555555;
  font-weight: 600;
  width: 70px;
  flex-shrink: 0;
}
.filter-date-group {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8px;
}
.filter-date-picker {
  flex: 1;
  height: 36px;
  line-height: 36px;
  background: #F2F3F5;
  border-radius: 8px;
  text-align: center;
  font-size: 13px;
  color: #1A1A1A;
}
.filter-sep {
  font-size: 13px;
  color: #999999;
  flex-shrink: 0;
}
.filter-input {
  flex: 1;
  height: 36px;
  background: #F2F3F5;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 13px;
  color: #1A1A1A;
}
.filter-actions {
  display: flex;
  gap: 12px;
  margin-top: 4px;
}
.filter-btn-reset {
  flex: 1;
  height: 40px;
  line-height: 40px;
  text-align: center;
  border-radius: 20px;
  border: 1.5px solid #E5E5E5;
  font-size: 14px;
  font-weight: 600;
  color: #555555;
}
.filter-btn-search {
  flex: 2;
  height: 40px;
  line-height: 40px;
  text-align: center;
  border-radius: 20px;
  background: #F5D547;
  font-size: 14px;
  font-weight: 700;
  color: #1A1A1A;
}

/* ── 列表区 ── */
.history-list {
  flex: 1;
  padding: 16px;
}

/* ── 左滑撤销 ── */
.swipe-wrapper {
  position: relative;
  overflow: hidden;
  border-radius: 16px;
  margin-bottom: 10px;
}
.swipe-container {
  position: relative;
  z-index: 2;
}
.swipe-action {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 72px;
  background: #1A1A1A;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  border-radius: 0 16px 16px 0;
}
.swipe-action-text {
  color: #F5D547;
  font-size: 14px;
  font-weight: 700;
}

.record-card {
  background: #FFFFFF;
  border-radius: 16px;
  padding: 14px 16px;
  display: flex;
  align-items: center;
  gap: 14px;
  box-shadow: 0 2px 14px rgba(0,0,0,0.09);
  overflow: hidden;
}

.record-dot {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #FDF0A0;
  border: 2px solid #F5D547;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
  color: #1A1A1A;
  font-weight: 700;
}

.record-info {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}
.record-model {
  font-size: 15px;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.record-process-tag {
  font-size: 13px;
  color: #1A1A1A;
  display: inline-block;
  margin-top: 3px;
  background: #F5D547;
  padding: 2px 8px;
  border-radius: 6px;
  font-weight: 700;
}
.record-order {
  font-size: 24px;
  color: #F5D547;
  display: block;
  margin-top: 4px;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-right {
  text-align: right;
  flex-shrink: 0;
  width: 72px;
}
.record-time {
  font-size: 14px;
  color: #555555;
  font-weight: 600;
  display: block;
}
.record-date {
  font-size: 12px;
  color: #999999;
  display: block;
  margin-top: 2px;
}

/* ── 加载/空态 ── */
.loading-more, .no-more {
  padding: 20px 0;
  text-align: center;
}
.loading-text, .no-more-text {
  font-size: 14px;
  color: #999999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}
.empty-icon { font-size: 48px; margin-bottom: 12px; }
.empty-title { font-size: 17px; font-weight: 600; color: #1A1A1A; margin-bottom: 8px; }
.empty-desc { font-size: 14px; color: #999999; }

/* ── 提交中全屏遮罩 ── */
.submitting-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(26,26,26,0.65);
  backdrop-filter: blur(6px);
  z-index: 3999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.submitting-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}
.submitting-spinner {
  width: 72px;
  height: 72px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.spinner-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 4px solid rgba(245,213,71,0.2);
  border-top-color: #F5D547;
  animation: spin 0.8s linear infinite;
}
.spinner-check {
  font-size: 24px;
  font-weight: 900;
  color: #F5D547;
  animation: pulse-check 1.2s ease-in-out infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
@keyframes pulse-check {
  0%, 100% { opacity: 0.4; transform: scale(0.9); }
  50% { opacity: 1; transform: scale(1.1); }
}
.submitting-text {
  color: #FFFFFF;
  font-size: 20px;
  font-weight: 800;
  letter-spacing: 2px;
}
.submitting-sub {
  color: rgba(255,255,255,0.55);
  font-size: 14px;
}

/* ── 撤销确认弹窗 ── */
.revoke-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(26,26,26,0.5);
  backdrop-filter: blur(4px);
  z-index: 5999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.revoke-card {
  width: 280px;
  background: #FFFFFF;
  border-radius: 24px;
  padding: 36px 28px 28px;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: revoke-pop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}
@keyframes revoke-pop {
  0% { transform: scale(0.7); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
.revoke-icon-wrap {
  width: 64px;
  height: 64px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}
.revoke-icon-bg {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: #F5D547;
  opacity: 0.15;
}
.revoke-icon-char {
  position: relative;
  width: 48px;
  height: 48px;
  line-height: 48px;
  text-align: center;
  font-size: 22px;
  font-weight: 900;
  color: #1A1A1A;
  background: #F5D547;
  border-radius: 50%;
  box-shadow: 0 4px 16px rgba(245,213,71,0.5);
}
.revoke-title {
  font-size: 20px;
  font-weight: 800;
  color: #1A1A1A;
  margin-bottom: 8px;
}
.revoke-desc {
  font-size: 14px;
  color: #555555;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 20px;
}
.revoke-btns {
  display: flex;
  gap: 12px;
  width: 100%;
}
.revoke-btn-cancel {
  flex: 1;
  height: 40px;
  line-height: 40px;
  text-align: center;
  border-radius: 20px;
  border: 1.5px solid #E5E5E5;
  font-size: 14px;
  font-weight: 600;
  color: #555555;
}
.revoke-btn-confirm {
  flex: 2;
  height: 40px;
  line-height: 40px;
  text-align: center;
  border-radius: 20px;
  background: #1A1A1A;
  font-size: 14px;
  font-weight: 700;
  color: #F5D547;
}
.revoke-bar {
  width: 40px;
  height: 4px;
  border-radius: 2px;
  background: #F5D547;
  margin-top: 20px;
}

/* ── 结果提示弹窗 ── */
.result-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(26,26,26,0.5);
  backdrop-filter: blur(4px);
  z-index: 6999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.result-card {
  width: 280px;
  background: #FFFFFF;
  border-radius: 24px;
  padding: 36px 28px 28px;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: result-pop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}
@keyframes result-pop {
  0% { transform: scale(0.7); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
.result-icon-wrap {
  margin-bottom: 16px;
}
.result-icon-char {
  width: 48px;
  height: 48px;
  line-height: 48px;
  text-align: center;
  font-size: 24px;
  font-weight: 900;
  border-radius: 50%;
  display: inline-block;
}
.result-success .result-icon-char {
  background: #F5D547;
  color: #1A1A1A;
  box-shadow: 0 4px 16px rgba(245,213,71,0.5);
}
.result-error .result-icon-char {
  background: #1A1A1A;
  color: #FFFFFF;
  box-shadow: 0 4px 16px rgba(26,26,26,0.25);
}
.result-title {
  font-size: 20px;
  font-weight: 800;
  color: #1A1A1A;
  margin-bottom: 8px;
}
.result-desc {
  font-size: 14px;
  color: #555555;
  text-align: center;
  line-height: 1.5;
}
.result-bar {
  width: 40px;
  height: 4px;
  border-radius: 2px;
  margin-top: 20px;
}
.result-success .result-bar { background: #F5D547; }
.result-error .result-bar { background: #1A1A1A; }
