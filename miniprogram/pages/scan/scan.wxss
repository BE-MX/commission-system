/* pages/scan/scan.wxss */

.scan-page {
  min-height: 100vh;
  background: #F2F3F5;
  display: flex;
  flex-direction: column;
}

/* ── 品牌顶栏 ── */
.brand-bar {
  background: #1A1A1A;
  flex-shrink: 0;
}
.brand-bar-inner {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
}
.logo-wrap {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  line-height: 1;
}
.logo-le {
  font-size: 22px;
  font-weight: 700;
  color: #F5D547;
  letter-spacing: 0.5px;
  font-style: italic;
}
.logo-shine {
  font-size: 22px;
  font-weight: 900;
  color: #F5D547;
  letter-spacing: -0.5px;
  font-style: italic;
}
.logo-hair {
  font-size: 22px;
  font-weight: 900;
  color: rgba(245,213,71,0.6);
  letter-spacing: -0.5px;
  font-style: italic;
}
.brand-bar-right {
  color: rgba(245,213,71,0.65);
  font-size: 13px;
  font-weight: 500;
}

/* ── 用户条（金黄背景） ── */
.user-bar {
  background: #F5D547;
  padding: 14px 20px 16px;
  display: flex;
  align-items: center;
  gap: 14px;
  flex-shrink: 0;
}
.user-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: #1A1A1A;
  color: #F5D547;
  font-size: 18px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.user-info {
  flex: 1;
}
.user-name {
  color: #1A1A1A;
  font-size: 17px;
  font-weight: 700;
  display: block;
}
.user-count {
  color: rgba(26,26,26,0.55);
  font-size: 14px;
  display: block;
  margin-top: 3px;
}
.history-btn {
  color: #1A1A1A;
  font-size: 13px;
  font-weight: 600;
  border: 1.5px solid rgba(26,26,26,0.3);
  padding: 5px 12px;
  border-radius: 14px;
  background: rgba(255,255,255,0.4);
  white-space: nowrap;
}

/* ── 扫码核心区 ── */
.scan-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32px 20px 24px;
  gap: 16px;
}

.scan-btn-wrap {
  position: relative;
  width: 220px;
  height: 220px;
}

/* 旋转光圈 */
.scan-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 4px solid transparent;
  background:
    linear-gradient(#F2F3F5, #F2F3F5) padding-box,
    conic-gradient(from 0deg, #F5D547, #D4B620, rgba(245,213,71,0.1), #F5D547) border-box;
  animation: spin 3s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 点状虚线外环 */
.scan-outer-ring {
  position: absolute;
  inset: -10px;
  border-radius: 50%;
  border: 1.5px dashed rgba(245,213,71,0.35);
}

/* 按钮主体 */
.scan-btn {
  position: absolute;
  inset: 10px;
  border-radius: 50%;
  background: linear-gradient(160deg, #FAFAFA 0%, #E8E9EB 60%, #D8DADD 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  box-shadow:
    inset 0 2px 6px rgba(255,255,255,0.9),
    inset 0 -3px 8px rgba(0,0,0,0.08),
    0 8px 32px rgba(0,0,0,0.18),
    0 0 0 3px #F5D547;
}
.scan-btn:active {
  transform: scale(0.97);
}

/* ── 二维码图标（对齐原型 SVG viewBox 80×80） ── */
.scan-icon {
  width: 86px;
  height: 86px;
  position: relative;
}

/* 三个定位框 — 对齐原型 <rect rx="5" stroke-width="5"> */
.qr-corner {
  position: absolute;
  width: 30px;
  height: 30px;
  border: 4px solid #1A1A1A;
  border-radius: 5px;
  box-sizing: border-box;
}
/* 内部填充方块 — 对齐原型 <rect rx="2 fill> */
.qr-inner {
  position: absolute;
  top: 50%; left: 50%;
  width: 16px; height: 16px;
  background: #1A1A1A;
  border-radius: 2px;
  transform: translate(-50%, -50%);
}

/* 定位框位置 */
.qr-tl { top: 2px; left: 2px; }
.qr-tr { top: 2px; right: 2px; }
.qr-bl { bottom: 2px; left: 2px; }

/* 右下角数据点阵 — 对齐原型 7 个小方块 */
.qr-dot {
  position: absolute;
  width: 7px;
  height: 7px;
  background: #1A1A1A;
  border-radius: 1px;
}
.qr-dot.d1 { bottom: 36px; right: 8px; }
.qr-dot.d2 { bottom: 36px; right: 18px; }
.qr-dot.d3 { bottom: 36px; right: 28px; }
.qr-dot.d4 { bottom: 24px; right: 8px; }
.qr-dot.d5 { bottom: 24px; right: 22px; }
.qr-dot.d6 { bottom: 12px; right: 8px; }
.qr-dot.d7 { bottom: 12px; right: 18px; }

/* 扫描线 — 虚线风格，对齐原型 stroke-dasharray */
.scan-line {
  position: absolute;
  left: 4px;
  right: 4px;
  height: 2.5px;
  background: repeating-linear-gradient(
    90deg,
    #F5D547 0px, #F5D547 4px,
    transparent 4px, transparent 7px
  );
  border-radius: 2px;
  animation: scan-move 2s ease-in-out infinite;
}
@keyframes scan-move {
  0% { top: 10px; }
  50% { top: 72px; }
  100% { top: 10px; }
}

.scan-btn-text {
  font-size: 22px;
  font-weight: 900;
  color: #1A1A1A;
  letter-spacing: 6px;
  text-shadow: 0 1px 2px rgba(255,255,255,0.8);
}

.scan-hint {
  color: #555555;
  font-size: 16px;
  font-weight: 500;
  letter-spacing: 0.5px;
}

/* ── 今日记录 ── */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
  margin-bottom: 10px;
  flex-shrink: 0;
}
.section-title {
  color: #1A1A1A;
  font-size: 17px;
  font-weight: 700;
}
.section-more {
  color: #1A1A1A;
  font-size: 13px;
  font-weight: 600;
  background: #FDF0A0;
  padding: 4px 10px;
  border-radius: 10px;
}

.record-list {
  padding: 0 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex: 1;
}

/* ── 左滑撤销 ── */
.swipe-wrapper {
  position: relative;
  overflow: hidden;
  border-radius: 16px;
}
.swipe-container {
  position: relative;
  z-index: 2;
}
.swipe-action {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 72px;
  background: #1A1A1A;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  border-radius: 0 16px 16px 0;
}
.swipe-action-text {
  color: #F5D547;
  font-size: 14px;
  font-weight: 700;
}
.record-card {
  background: #FFFFFF;
  border-radius: 16px;
  padding: 14px 16px;
  display: flex;
  align-items: center;
  gap: 14px;
  box-shadow: 0 2px 14px rgba(0,0,0,0.09);
}
.record-dot {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #FDF0A0;
  border: 2px solid #F5D547;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
  color: #1A1A1A;
  font-weight: 700;
}
.record-info {
  flex: 1;
}
.record-model {
  font-size: 15px;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
}
.record-process-tag {
  font-size: 13px;
  color: #1A1A1A;
  display: inline-block;
  margin-top: 3px;
  background: #F5D547;
  padding: 2px 8px;
  border-radius: 6px;
  font-weight: 700;
}
.record-order {
  font-size: 24px;
  color: #F5D547;
  display: block;
  margin-top: 4px;
  font-weight: 700;
}
.record-time {
  font-size: 13px;
  color: #999999;
  flex-shrink: 0;
}

/* ── 空态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 0;
}
.empty-icon {
  font-size: 48px;
  margin-bottom: 12px;
}
.empty-title {
  font-size: 17px;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 8px;
}
.empty-desc {
  font-size: 14px;
  color: #999999;
}

/* ── 工单识别中全屏遮罩 ── */
.loading-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(26,26,26,0.65);
  backdrop-filter: blur(6px);
  z-index: 3999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}
.loading-spinner {
  width: 80px;
  height: 80px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.loading-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 3px solid rgba(245,213,71,0.15);
  border-top-color: #F5D547;
  animation: spin 0.9s linear infinite;
}
/* 小型二维码图标（loading 中间） */
.loading-scan-icon {
  width: 36px;
  height: 36px;
  position: relative;
}
.lsi-corner {
  position: absolute;
  width: 10px;
  height: 10px;
  border: 2px solid #F5D547;
  border-radius: 2px;
  box-sizing: border-box;
}
.lsi-tl { top: 0; left: 0; border-right: none; border-bottom: none; }
.lsi-tr { top: 0; right: 0; border-left: none; border-bottom: none; }
.lsi-bl { bottom: 0; left: 0; border-right: none; border-top: none; }
.lsi-line {
  position: absolute;
  left: 4px; right: 4px;
  height: 2px;
  background: rgba(245,213,71,0.5);
  border-radius: 1px;
  top: 50%;
  animation: lsi-scan 1.4s ease-in-out infinite;
}
@keyframes lsi-scan {
  0%, 100% { top: 20%; }
  50% { top: 72%; }
}
.loading-text {
  color: #FFFFFF;
  font-size: 20px;
  font-weight: 800;
  letter-spacing: 2px;
}
.loading-sub {
  color: rgba(255,255,255,0.55);
  font-size: 14px;
}

/* ── 提交中全屏遮罩 ── */
.submitting-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(26,26,26,0.65);
  backdrop-filter: blur(6px);
  z-index: 3999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.submitting-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}
.submitting-spinner {
  width: 72px;
  height: 72px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.spinner-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 4px solid rgba(245,213,71,0.2);
  border-top-color: #F5D547;
  animation: spin 0.8s linear infinite;
}
.spinner-check {
  font-size: 28px;
  font-weight: 900;
  color: #F5D547;
  animation: pulse-check 1.2s ease-in-out infinite;
}
@keyframes pulse-check {
  0%, 100% { opacity: 0.4; transform: scale(0.9); }
  50% { opacity: 1; transform: scale(1.1); }
}
.submitting-text {
  color: #FFFFFF;
  font-size: 20px;
  font-weight: 800;
  letter-spacing: 2px;
}
.submitting-sub {
  color: rgba(255,255,255,0.55);
  font-size: 14px;
}

/* ── 报工成功弹窗 ── */
.success-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(26,26,26,0.5);
  backdrop-filter: blur(4px);
  z-index: 4999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.success-card {
  width: 280px;
  background: #FFFFFF;
  border-radius: 24px;
  padding: 36px 28px 28px;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: success-pop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}
@keyframes success-pop {
  0% { transform: scale(0.7); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
.success-icon-wrap {
  width: 64px;
  height: 64px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}
.success-icon-bg {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: #F5D547;
  opacity: 0.15;
}
.success-icon-check {
  position: relative;
  width: 48px;
  height: 48px;
  line-height: 48px;
  text-align: center;
  font-size: 24px;
  font-weight: 900;
  color: #1A1A1A;
  background: #F5D547;
  border-radius: 50%;
  box-shadow: 0 4px 16px rgba(245,213,71,0.5);
}
.success-title {
  font-size: 20px;
  font-weight: 800;
  color: #1A1A1A;
  margin-bottom: 8px;
}
.success-desc {
  font-size: 14px;
  color: #555555;
  text-align: center;
  line-height: 1.5;
}
.success-bar {
  width: 40px;
  height: 4px;
  border-radius: 2px;
  background: #F5D547;
  margin-top: 20px;
}

/* ── 错误/警告弹窗 ── */
.error-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(26,26,26,0.5);
  backdrop-filter: blur(4px);
  z-index: 5999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.error-card {
  width: 280px;
  background: #FFFFFF;
  border-radius: 24px;
  padding: 36px 28px 28px;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: error-pop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}
@keyframes error-pop {
  0% { transform: scale(0.7); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
.error-icon-wrap {
  width: 64px;
  height: 64px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}
.error-icon-bg {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: #1A1A1A;
  opacity: 0.08;
}
.error-icon-char {
  position: relative;
  width: 48px;
  height: 48px;
  line-height: 48px;
  text-align: center;
  font-size: 26px;
  font-weight: 900;
  color: #FFFFFF;
  background: #1A1A1A;
  border-radius: 50%;
  box-shadow: 0 4px 16px rgba(26,26,26,0.25);
}
.error-title {
  font-size: 20px;
  font-weight: 800;
  color: #1A1A1A;
  margin-bottom: 8px;
}
.error-desc {
  font-size: 14px;
  color: #555555;
  text-align: center;
  line-height: 1.6;
  white-space: pre-line;
  margin-bottom: 20px;
}
.error-btn {
  background: #1A1A1A;
  color: #F5D547;
  font-size: 15px;
  font-weight: 700;
  padding: 10px 40px;
  border-radius: 22px;
  text-align: center;
}
.error-bar {
  width: 40px;
  height: 4px;
  border-radius: 2px;
  background: #1A1A1A;
  margin-top: 20px;
}

/* ── 撤销确认按钮组 ── */
.revoke-btns {
  display: flex;
  gap: 12px;
  width: 100%;
}
.revoke-btn-cancel {
  flex: 1;
  height: 40px;
  line-height: 40px;
  text-align: center;
  border-radius: 20px;
  border: 1.5px solid #E5E5E5;
  font-size: 14px;
  font-weight: 600;
  color: #555555;
}
.revoke-btn-confirm {
  flex: 2;
  height: 40px;
  line-height: 40px;
  text-align: center;
  border-radius: 20px;
  background: #1A1A1A;
  font-size: 14px;
  font-weight: 700;
  color: #F5D547;
}
