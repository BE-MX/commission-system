# ── 应用环境 ──────────────────────────────────────────
# development / production. production 模式下会强校验下方关键配置
APP_ENV=development

# ── 提成系统数据库（读写）──────────────────────────────
COMMISSION_DB_HOST=localhost
COMMISSION_DB_PORT=3306
COMMISSION_DB_USER=commission
COMMISSION_DB_PASSWORD=changeme
COMMISSION_DB_NAME=commission_db

# ── 业务数据库（只读，同一RDS实例）──────────────────────
BUSINESS_DB_NAME=lsordertest

# ── DHL API ──────────────────────────────────────────
DHL_API_USERNAME=
DHL_API_PASSWORD=
DHL_API_ENV=test

# ── FedEx API ────────────────────────────────────────
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_SANDBOX=false

# ── Tracking poll config ─────────────────────────────
TRACKING_POLL_BATCH_SIZE=50
STAGING_SCAN_BATCH_SIZE=100

# ── APScheduler 定时任务 ─────────────────────────────
# false 时不注册任何 cron/interval 任务,适合 worker/scheduler 分离部署
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Shanghai

# ── 设计预约模块 ──────────────────────────────────────
DESIGN_DEFAULT_DAILY_CAPACITY=3
DESIGN_REQUEST_NO_PREFIX=DSR
DESIGN_TASK_NO_PREFIX=DST

# ── JWT / Auth ───────────────────────────────────────
# production 模式下 JWT_SECRET_KEY 不能是占位符,COOKIE_SECURE 必须为 true
JWT_SECRET_KEY=change-this-to-a-random-64-char-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false

# ── CORS ─────────────────────────────────────────────
# 逗号分隔的域名列表。production 模式下不允许含 localhost
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8000

# ── AI 加密 ──────────────────────────────────────────
# AES-256-GCM 加密 AI Provider 的 api_key。production 模式下必须显式配置
ARK_AI_ENCRYPTION_KEY=

# ── 钉钉 Webhook 机器人（群消息推送）──────────────────
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN_HERE
DINGTALK_WEBHOOK_SECRET=

# ── 钉钉企业内部应用（审批、工作通知）──────────────────
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=

# ── 钉钉回调 ─────────────────────────────────────────
DINGTALK_CALLBACK_AES_KEY=
DINGTALK_CALLBACK_TOKEN=
